#!/usr/bin/env sh
set -eu

VERSION="__VERSION__"
REPO="webxsid/crona-node"
INSTALL_DIR="${CRONA_INSTALL_DIR:-$HOME/.local/bin}"
VERSION_FILE="${INSTALL_DIR}/.crona-version"
CRONA_HOME="${CRONA_HOME:-$HOME/.crona}"
ASSETS_DIR="${CRONA_HOME}/assets/bundled"

prompt_replace() {
  installed_version="$1"

  if [ "${CRONA_INSTALL_FORCE:-0}" = "1" ]; then
    return 0
  fi

  if [ -n "${installed_version}" ]; then
    if [ "${installed_version}" = "${VERSION}" ]; then
      printf 'Crona %s is already installed in %s.\n' "${installed_version}" "${INSTALL_DIR}"
      printf 'Reinstall %s? [y/N] ' "${VERSION}"
    else
      printf 'Crona %s is already installed in %s.\n' "${installed_version}" "${INSTALL_DIR}"
      printf 'Install %s over it? [y/N] ' "${VERSION}"
    fi
  else
    printf 'Existing Crona binaries were found in %s.\n' "${INSTALL_DIR}"
    printf 'Install %s over them? [y/N] ' "${VERSION}"
  fi

  if [ ! -t 0 ]; then
    echo
    echo "Install cancelled. Re-run with CRONA_INSTALL_FORCE=1 to replace the existing install non-interactively." >&2
    exit 1
  fi

  read -r reply
  case "${reply}" in
    y|Y|yes|YES)
      return 0
      ;;
    *)
      echo "Install cancelled."
      exit 0
      ;;
  esac
}

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "darwin" ;;
    Linux) echo "linux" ;;
    *)
      echo "Unsupported OS: $(uname -s)" >&2
      exit 1
      ;;
  esac
}

detect_arch() {
  case "$(uname -m)" in
    arm64|aarch64) echo "arm64" ;;
    x86_64|amd64) echo "amd64" ;;
    *)
      echo "Unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

OS="$(detect_os)"
ARCH="$(detect_arch)"
BASE_URL="https://github.com/${REPO}/releases/download/${VERSION}"
KERNEL_URL="${BASE_URL}/crona-kernel-${VERSION}-${OS}-${ARCH}"
TUI_URL="${BASE_URL}/crona-tui-${VERSION}-${OS}-${ARCH}"
ASSETS_URL="${BASE_URL}/crona-assets-${VERSION}.tar.gz"

mkdir -p "${INSTALL_DIR}"
mkdir -p "${ASSETS_DIR}"

INSTALLED_VERSION=""
if [ -f "${VERSION_FILE}" ]; then
  INSTALLED_VERSION="$(tr -d '\n' < "${VERSION_FILE}")"
fi

if [ -x "${INSTALL_DIR}/crona-kernel" ] || [ -x "${INSTALL_DIR}/crona-tui" ]; then
  prompt_replace "${INSTALLED_VERSION}"
fi

echo "Installing Crona ${VERSION} to ${INSTALL_DIR}"
curl -fsSL "${KERNEL_URL}" -o "${INSTALL_DIR}/crona-kernel.tmp"
curl -fsSL "${TUI_URL}" -o "${INSTALL_DIR}/crona-tui.tmp"
curl -fsSL "${ASSETS_URL}" -o "${ASSETS_DIR}/crona-assets.tmp.tar.gz"
chmod +x "${INSTALL_DIR}/crona-kernel.tmp" "${INSTALL_DIR}/crona-tui.tmp"
mv "${INSTALL_DIR}/crona-kernel.tmp" "${INSTALL_DIR}/crona-kernel"
mv "${INSTALL_DIR}/crona-tui.tmp" "${INSTALL_DIR}/crona-tui"
rm -rf "${ASSETS_DIR}/export"
tar -xzf "${ASSETS_DIR}/crona-assets.tmp.tar.gz" -C "${ASSETS_DIR}"
rm -f "${ASSETS_DIR}/crona-assets.tmp.tar.gz"
printf '%s\n' "${VERSION}" > "${VERSION_FILE}"

echo
echo "Installed:"
echo "  ${INSTALL_DIR}/crona-kernel"
echo "  ${INSTALL_DIR}/crona-tui"
echo "  ${ASSETS_DIR}/export"
echo
echo "Make sure ${INSTALL_DIR} is on your PATH."
echo "Then run:"
echo "  crona-tui"
